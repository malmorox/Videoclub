<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Videoclub" parent="Theme.Material3.DayNight" />

    <style name="Theme.Videoclub" parent="Base.Theme.Videoclub">
        <item name="colorPrimary">@color/action_bar_bg</item>
        <item name="actionBarStyle">@style/ActionBarStyle</item>
        <item name="actionBarTheme">@style/ActionBarTheme</item>
    </style>

    <style name="ActionBarStyle" parent="Widget.AppCompat.ActionBar">
        <item name="background">@color/action_bar_bg</item>
        <item name="titleTextStyle">@style/ActionBarTitleText</item>
    </style>

    <style name="ActionBarTheme" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="ActionBarTitleText" parent="TextAppearance.Widget.AppCompat.Toolbar.Title">
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">20sp</item>
    </style>
</resources>